{
  manifest_version: 3,
  name: PriceWatch - Subscription Price Tracker,
  version: 1.0.0,
  description: Automatically track price changes on your SaaS subscriptions and recurring services,
  permissions: [
    storage,
    alarms,
    notifications,
    tabs,
    scripting
  ],
  host_permissions: [
    http://*/*,
    https://*/*
  ],
  background: {
    service_worker: background.js,
    type: module
  },
  content_scripts: [
    {
      matches: [http://*/*, https://*/*],
      js: [content.js],
      run_at: document_idle
    }
  ],
  action: {
    default_popup: popup/popup.html,
    default_icon: {
      16: icons/icon16.png,
      48: icons/icon48.png,
      128: icons/icon128.png
    }
  },
  options_page: options/options.html,
  icons: {
    16: icons/icon16.png,
    48: icons/icon48.png,
    128: icons/icon128.png
  }
}
